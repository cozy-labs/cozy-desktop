@require '_item_line'
@require './node_modules/cozy-ui/stylus/components/badge.styl'

.user-alerts
  flex 0 0 auto
  max-height 40vh
  overflow-y auto

.alert-line
  @extend $item-line
  padding-bottom 0
  cursor: default

.alert-line .file-name-wrapper
  .file-name-open
    display: none
    vertical-align: baseline
    margin-left: rem(4)

  &:hover
    .file-name-open
      display: inline-block

.file-alert-icon
  @extend $badge-root
  position absolute
  left 1em
  top $itemLinePaddingTop
  width 2rem
  height 2rem

  .file-type
    position static
    width 100%
    height 100%

  .badge
    @extend $badge
    @extend $badge--size-small
    @extend $badge--error
    bottom -2px
    right -2px
    top auto
    left auto
    z-index 3

  .file-type.file-type-system-error
    border-radius 12px
    background-color: var(--error-main-background-contrast-opacity, rgba(255, 51, 71, 0.12))
    background-size rem(14) rem(14)

.alert-btn
  background: none
  border: none
  padding: rem(4) rem(8)
  border-radius: rem(4)
  font: inherit
  color: inherit
  cursor: pointer
  text-decoration: none
  display: inline-flex
  align-items: center
  margin-right: rem(6)

  &:hover
    background-color: unquote("color-mix(in srgb, currentColor 10%, transparent)")

  &--primary
    font-weight: bold
    color: var(--primaryColorDark)

  &--danger
    font-weight: bold
    color: var(--pomegranate)

  &--danger-light
    color: var(--pomegranate)

.alert-btn-icon
  margin-right: rem(3)

.alert-btn svg
  fill: currentColor
